{
  "name": "fttddwa",
  "version": "1.6.0",
  "description": "Federation of Tamil Nadu Tent Dealers & Decorators Welfare Association - Member Management System",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.local -- next dev",
    "build": "npx prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "db:migrate": "dotenv -e .env.local -- npx prisma migrate dev",
    "db:migrate:prod": "npx prisma migrate deploy && npx prisma generate",
    "db:generate": "npx prisma generate",
    "db:seed": "dotenv -e .env.local -- npx prisma generate && dotenv -e .env.local ts-node --project tsconfig.seed.json prisma/seed.ts",
    "db:setup": "dotenv -e .env.local -- npx prisma migrate dev && dotenv -e .env.local -- npx prisma generate && dotenv -e .env.local ts-node --project tsconfig.seed.json prisma/seed.ts",
    "db:studio": "dotenv -e .env.local -- npx prisma studio",
    "db:reset": "dotenv -e .env.local -- npx prisma migrate reset",
    "worker": "dotenv -e .env.local -- ts-node -r tsconfig-paths/register --project tsconfig.worker.json worker.ts",
    "worker:build": "npx tsc --project tsconfig.worker.json",
    "worker:start": "node dist/worker/worker.js",
    "prod:start": "pm2 start ecosystem.config.js",
    "prod:stop": "pm2 stop ecosystem.config.js",
    "prod:restart": "pm2 restart ecosystem.config.js",
    "prod:status": "pm2 status",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^5.22.0",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "jose": "^5.9.6",
    "lucide-react": "^0.460.0",
    "multer": "^1.4.5-lts.1",
    "next": "^15.0.3",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.1",
    "react-hot-toast": "^2.4.1",
    "sanitize-html": "^2.13.1",
    "sharp": "^0.33.5",
    "swagger-ui-react": "^5.18.2",
    "tailwind-merge": "^2.5.5",
    "tsconfig-paths": "^4.2.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.2",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.3",
    "@types/pdfkit": "^0.13.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sanitize-html": "^2.13.0",
    "@types/swagger-ui-react": "^4.18.3",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.0.3",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.15",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
