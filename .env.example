# ============================================
# FTTDDWA - Environment Variables Example
# Copy to .env.local for local development
# ============================================

# Application
APP_ENV=development
TIMEZONE=Asia/Kolkata
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="FTTDDWA Member Portal"

# Database (MySQL)
# Local development:
DATABASE_URL="mysql://fttddwa_user:your_password@localhost:3306/fttddwa_db"
# SiteGround (production) — enable remote MySQL in cPanel first, then:
# DATABASE_URL="mysql://db_user:db_pass@sg-host.siteground.com:3306/db_name?ssl={"rejectUnauthorized":false}&connection_limit=5"

# JWT Secrets (generate strong random strings in production)
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Encryption (for sensitive fields like Aadhaar)
ENCRYPTION_KEY=your_32_char_aes256_encryption_key_here

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Vercel Blob (for file uploads on Vercel — get token from Vercel dashboard → Storage → Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxx

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Membership ID Prefix
MEMBERSHIP_ID_PREFIX=FTTD

# Admin Seed (used for initial setup only)
SEED_ADMIN_EMAIL=admin@fttddwa.org
SEED_ADMIN_PASSWORD=Admin@123456
SEED_ADMIN_NAME="Super Admin"
